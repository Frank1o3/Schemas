{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frank1o3.github.io/Schemas/schemas/roblox/fastflags.schema.json#v1.0.0",
  "title": "Roblox Fast Flags",
  "description": "Validation schema for Roblox ClientAppSettings Fast Flags",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "FFlagDebugGraphicsPreferVulkan": {
      "type": "boolean",
      "description": "Prefer Vulkan rendering backend",
      "allowListStatus": "allowed",
      "source": "roblox-allowlist"
    },
    "DFIntTextureQualityOverride": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3,
      "description": "Overrides texture quality level",
      "allowListStatus": "allowed"
    },
    "DFIntTaskSchedulerTargetFps": {
      "type": "integer",
      "minimum": 30,
      "maximum": 1000,
      "description": "Community FPS scheduler flag",
      "allowListStatus": "not-allowlisted",
      "notes": "Ignored by current Roblox clients"
    }
  }
}