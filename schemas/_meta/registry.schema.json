{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
        "schema"
    ],
    "properties": {
        "schema": {
            "type": "object",
            "required": [
                "title",
                "type"
            ],
            "properties": {
                "title": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                },
                "required": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "properties": {
                    "type": "object"
                },
                "additionalProperties": {
                    "type": [
                        "boolean",
                        "object"
                    ]
                },
                "$defs": {
                    "type": "object"
                }
            },
            "additionalProperties": true
        },
        "flags": {
            "type": "object",
            "additionalProperties": {
                "type": "object",
                "required": [
                    "type"
                ],
                "properties": {
                    "type": {
                        "enum": [
                            "boolean",
                            "integer",
                            "string",
                            "number",
                            "object",
                            "array"
                        ]
                    },
                    "description": {
                        "type": "string"
                    },
                    "minimum": {
                        "type": "number"
                    },
                    "maximum": {
                        "type": "number"
                    },
                    "pattern": {
                        "type": "string"
                    },
                    "enum": {
                        "type": "array"
                    },
                    "default": {}
                },
                "additionalProperties": true
            }
        }
    },
    "anyOf": [
        {
            "required": [
                "flags"
            ]
        },
        {
            "not": {
                "required": [
                    "flags"
                ]
            }
        }
    ]
}